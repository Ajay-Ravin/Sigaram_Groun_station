@dataclass
class CanSatTelemetry:
    """CanSat telemetry data"""
    altitude: float = 0.0  # meters
    velocity: float = 0.0  # m/s
    pressure: float = 1013.0  # hPa
    temperature: float = 25.0  # °C
    latitude: float = 0.0
    longitude: float = 0.0
    satellite_count: int = 8
    fix_type: str = "3D"
    battery: int = 74
    signal: int = -71
    state: CanSatState = CanSatState.IDLE


