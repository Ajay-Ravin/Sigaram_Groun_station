class SidebarWidget(QWidget):
    """Left navigation sidebar with enhanced styling"""
    
    page_selected = pyqtSignal(int)
    
    def __init__(self):
        super().__init__()
        self.setMinimumWidth(210)
        self.setMaximumWidth(210)
        self.setStyleSheet(f"""
            QWidget {{
                background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                    stop:0 {Color.DARK_BG}, stop:1 {Color.DARK_PANEL});
                border-right: 2px solid {Color.BORDER_HIGHLIGHT};
            }}
        """)
        
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 25, 0, 25)
        layout.setSpacing(10)
        
        # Navigation items
        self.nav_buttons = []
        nav_items = [
            ("OVERVIEW", "Combined Status", 0, "📊"),
            ("ROCKET", "Flight Data", 1, "🚀"),
            ("CANSAT", "Deployment", 2, "🛰️"),
        ]
        
        for title, subtitle, page_id, emoji in nav_items:
            btn = self.create_nav_button(title, subtitle, page_id, emoji)
            layout.addWidget(btn)
            self.nav_buttons.append((btn, page_id))
        
        # Highlight first button
        self.highlight_button(0)
        
        layout.addStretch()
    
    def create_nav_button(self, title: str, subtitle: str, page_id: int, emoji: str) -> QWidget:
        """Create a navigation button with enhanced styling"""
        widget = QWidget()
        widget_layout = QVBoxLayout(widget)
        widget_layout.setContentsMargins(15, 12, 15, 12)
        widget_layout.setSpacing(3)
        
        title_label = QLabel(f"{emoji} {title}")
        title_label.setFont(QFont("Monaco", 11, QFont.Weight.Bold))
        title_label.setStyleSheet(f"color: {Color.ACCENT_CYAN};")
        
        subtitle_label = QLabel(subtitle)
        subtitle_label.setFont(QFont("Monaco", 8))
        subtitle_label.setStyleSheet(f"color: {Color.TEXT_SECONDARY};")
        
        widget_layout.addWidget(title_label)
        widget_layout.addWidget(subtitle_label)
        
        widget.setCursor(Qt.CursorShape.PointingHandCursor)
        widget.page_id = page_id
        widget.title = title
        
        # Mouse click handling
        widget.mousePressEvent = lambda e: self.on_nav_click(page_id, widget)
        
        return widget
    
    def on_nav_click(self, page_id: int, widget: QWidget):
        """Handle navigation click"""
        self.highlight_button(page_id)
        self.page_selected.emit(page_id)
    
    def highlight_button(self, page_id: int):
        """Highlight selected navigation button with enhanced effect"""
        for btn, pid in self.nav_buttons:
            if pid == page_id:
                btn.setStyleSheet(f"""
                    QWidget {{
                        background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                            stop:0 {Color.DARK_PANEL_HOVER}, 
                            stop:1 {Color.DARK_PANEL});
                        border-left: 4px solid {Color.ACCENT_CYAN};
                        border-radius: 4px;
                    }}
                """)
            else:
                btn.setStyleSheet("background-color: transparent;")


class TelemetryGraphWidget(QWidget):
    """Real-time telemetry graph using PyQtGraph"""
    
    def __init__(self, title: str, color: str):
        super().__init__()
        self.title = title
        self.color = color
        self.data_points: List[float] = []
        
        self.setMinimumHeight(200)
        self.setStyleSheet(f"background-color: {Color.DARK_PANEL}; border: 1px solid {Color.BORDER};")
        
        layout = QVBoxLayout(self)
        layout.setContentsMargins(5, 5, 5, 5)
        
        # Title
        title_label = QLabel(title)
        title_label.setFont(QFont("Consolas", 10, QFont.Weight.Bold))
        title_label.setStyleSheet(f"color: {Color.ACCENT_CYAN};")
        layout.addWidget(title_label)
        
        try:
            # Create PyQtGraph PlotWidget
            self.plot_widget = pg.PlotWidget()
            self.plot_widget.setLabel('left', title, units='')
            self.plot_widget.setLabel('bottom', 'Time', units='samples')
            self.plot_widget.setTitle(title)
            
            # Style the plot
            self.plot_widget.setBackground(QColor(Color.DARK_PANEL))
            
            # Configure grid
            self.plot_widget.showGrid(True, True, alpha=0.3)
            
            # Create the line for plotting
            self.line = self.plot_widget.plot(pen=pg.mkPen(color=self.color, width=2))
            
            layout.addWidget(self.plot_widget)
        except Exception as e:
            print(f"[ERROR] Failed to create TelemetryGraphWidget: {e}")
            error_label = QLabel(f"Graph Error: {str(e)[:50]}")
            error_label.setStyleSheet("color: #FF3333;")
            layout.addWidget(error_label)
    
    def add_data_point(self, value: float):
        """Add new data point"""
        self.data_points.append(value)
        if len(self.data_points) > 100:
            self.data_points.pop(0)
        self.update_chart()
    
    def update_chart(self):
        """Update chart visualization"""
        try:
            if self.data_points and hasattr(self, 'line'):
                self.line.setData(self.data_points)
        except Exception as e:
            print(f"[ERROR] Failed to update chart: {e}")


