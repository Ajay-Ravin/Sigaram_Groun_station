class OverviewPage(QWidget):
    """Overview page showing rocket and CanSat status side-by-side"""
    
    def __init__(self, telemetry_interface: TelemetryDataInterface):
        super().__init__()
        self.telemetry_interface = telemetry_interface
        
        layout = QHBoxLayout(self)
        layout.setContentsMargins(10, 10, 10, 10)
        layout.setSpacing(10)
        
        # Rocket section (left)
        self.rocket_section = self.create_section("ROCKET", "rocket")
        layout.addWidget(self.rocket_section)
        
        # CanSat section (right)
        self.cansat_section = self.create_section("CANSAT", "cansat")
        layout.addWidget(self.cansat_section)
        
        # Connect signals
        telemetry_interface.rocket_updated.connect(self.update_rocket)
        telemetry_interface.cansat_updated.connect(self.update_cansat)
    
    def create_section(self, title: str, section_type: str) -> QWidget:
        """Create rocket or CanSat section"""
        container = QWidget()
        layout = QVBoxLayout(container)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(10)
        
        # Title
        title_label = QLabel(title)
        title_label.setFont(QFont("Consolas", 14, QFont.Weight.Bold))
        title_label.setStyleSheet(f"color: {Color.ACCENT_CYAN};")
        layout.addWidget(title_label)
        
        # State bar
        if section_type == "rocket":
            states = [s.value for s in RocketState]
            color = Color.MINT_GREEN
            self.rocket_state_bar = StateBarWidget(states, color)
            layout.addWidget(self.rocket_state_bar)
            
            # Gauges
            gauge_layout = QGridLayout()
            self.rocket_gauges = {
                "Altitude": TelemetryGaugeWidget("Altitude", "m", Color.ACCENT_CYAN, 0, 6000),
                "Velocity": TelemetryGaugeWidget("Velocity", "m/s", Color.MINT_GREEN, 0, 1000),
                "Acceleration": TelemetryGaugeWidget("Acceleration", "m/s²", Color.AMBER, -20, 100),
                "Temperature": TelemetryGaugeWidget("Temperature", "°C", Color.BLUE, -40, 80),
            }
            for i, (name, gauge) in enumerate(self.rocket_gauges.items()):
                gauge_layout.addWidget(gauge, i // 2, i % 2)
            layout.addLayout(gauge_layout)
            
            # Graphs
            graph_layout = QGridLayout()
            self.rocket_graphs = {
                "Altitude": TelemetryGraphWidget("Altitude Trace", Color.ACCENT_CYAN),
                "Velocity": TelemetryGraphWidget("Velocity Trace", Color.MINT_GREEN),
            }
            for i, (name, graph) in enumerate(self.rocket_graphs.items()):
                graph_layout.addWidget(graph, 0, i)
            layout.addLayout(graph_layout)
        
        else:  # CanSat
            states = [s.value for s in CanSatState]
            color = Color.BLUE
            self.cansat_state_bar = StateBarWidget(states, color)
            layout.addWidget(self.cansat_state_bar)
            
            # Gauges
            gauge_layout = QGridLayout()
            self.cansat_gauges = {
                "Altitude": TelemetryGaugeWidget("Altitude", "m", Color.ACCENT_CYAN, 0, 2000),
                "Velocity": TelemetryGaugeWidget("Velocity", "m/s", Color.MINT_GREEN, -100, 200),
                "Pressure": TelemetryGaugeWidget("Pressure", "hPa", Color.AMBER, 600, 1200),
                "Temperature": TelemetryGaugeWidget("Temperature", "°C", Color.BLUE, -40, 80),
            }
            for i, (name, gauge) in enumerate(self.cansat_gauges.items()):
                gauge_layout.addWidget(gauge, i // 2, i % 2)
            layout.addLayout(gauge_layout)
            
            # Graphs
            graph_layout = QGridLayout()
            self.cansat_graphs = {
                "Altitude": TelemetryGraphWidget("Altitude Trace", Color.ACCENT_CYAN),
                "Pressure": TelemetryGraphWidget("Pressure Trace", Color.AMBER),
            }
            for i, (name, graph) in enumerate(self.cansat_graphs.items()):
                graph_layout.addWidget(graph, 0, i)
            layout.addLayout(graph_layout)
        
        return container
    
    def update_rocket(self, telemetry: RocketTelemetry):
        """Update rocket data"""
        self.rocket_state_bar.set_state(telemetry.state.value)
        self.rocket_gauges["Altitude"].set_value(telemetry.altitude)
        self.rocket_gauges["Velocity"].set_value(telemetry.velocity)
