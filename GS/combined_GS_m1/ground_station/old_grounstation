class TelemetryDataInterface(QObject):
    """Interface for receiving telemetry data from backend"""
    
    rocket_updated = pyqtSignal(RocketTelemetry)
    cansat_updated = pyqtSignal(CanSatTelemetry)
    
    def __init__(self):
        super().__init__()
        self.rocket = RocketTelemetry()
        self.cansat = CanSatTelemetry()
        self.elapsed_time = 0
        
        self.rocket_history: List[RocketTelemetry] = []
        self.cansat_history: List[CanSatTelemetry] = []
    
    def update_rocket_telemetry(self, telemetry: RocketTelemetry):
        """Receive rocket telemetry from backend"""
        self.rocket = telemetry
        self.rocket_history.append(RocketTelemetry(**vars(self.rocket)))
        if len(self.rocket_history) > 200:  # Keep last 200 points
            self.rocket_history.pop(0)
        self.rocket_updated.emit(self.rocket)
    
    def update_cansat_telemetry(self, telemetry: CanSatTelemetry):
        """Receive CanSat telemetry from backend"""
        self.cansat = telemetry
        self.cansat_history.append(CanSatTelemetry(**vars(self.cansat)))
        if len(self.cansat_history) > 200:  # Keep last 200 points
            self.cansat_history.pop(0)
        self.cansat_updated.emit(self.cansat)
    
    def update_elapsed_time(self, elapsed_seconds: float):
        """Update mission elapsed time"""
        self.elapsed_time = elapsed_seconds
    
    def get_rocket_history(self, last_n: int = 60) -> List[RocketTelemetry]:
        """Get last N rocket telemetry points"""
        return self.rocket_history[-last_n:]
    
    def get_cansat_history(self, last_n: int = 60) -> List[CanSatTelemetry]:
        """Get last N CanSat telemetry points"""
        return self.cansat_history[-last_n:]


