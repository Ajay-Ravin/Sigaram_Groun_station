class GroundStationApp(QMainWindow):
    """Main ground station application with polished UI"""
    
    def __init__(self):
        super().__init__()
        
        self.setWindowTitle("🚀 CANSAT & ROCKET GROUND STATION 🛰️")
        self.setMinimumSize(1500, 950)
        self.setWindowIcon(self.style().standardIcon(self.style().StandardPixmap.SP_ComputerIcon))
        
        # Position window in center of screen
        screen = QApplication.primaryScreen()
        if screen:
            screen_geometry = screen.geometry()
            x = (screen_geometry.width() - 1500) // 2
            y = (screen_geometry.height() - 950) // 2
            self.move(x, y)
        
        # Create telemetry data interface (receives data from backend)
        self.telemetry_interface = TelemetryDataInterface()
        
        # Main container
        main_widget = QWidget()
        main_layout = QVBoxLayout(main_widget)
        main_layout.setContentsMargins(0, 0, 0, 0)
        main_layout.setSpacing(0)
        
        # Status bar
        self.status_bar = StatusBarWidget()
        main_layout.addWidget(self.status_bar)
        
        # Content area
        content_layout = QHBoxLayout()
        content_layout.setContentsMargins(0, 0, 0, 0)
        content_layout.setSpacing(0)
        
        # Sidebar
        self.sidebar = SidebarWidget()
        self.sidebar.page_selected.connect(self.on_page_selected)
        content_layout.addWidget(self.sidebar)
        
        # Pages container
        self.pages = QStackedWidget()
        
        # Create pages with telemetry interface
        self.overview_page = OverviewPage(self.telemetry_interface)
        self.rocket_page = RocketDetailPage(self.telemetry_interface)
        self.cansat_page = CanSatDetailPage(self.telemetry_interface)
        
        self.pages.addWidget(self.overview_page)  # 0
        self.pages.addWidget(self.rocket_page)     # 1
        self.pages.addWidget(self.cansat_page)     # 2
        
        content_layout.addWidget(self.pages)
        
        # Add to main layout
        main_layout.addLayout(content_layout)
        
        self.setCentralWidget(main_widget)
        
        # Set dark theme with gradient background
        self.setStyleSheet(f"""
            QMainWindow {{
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                    stop:0 {Color.DARK_BG}, stop:1 {Color.DARK_PANEL});
            }}
        """)
        
        # Update status bar timer
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_status)
        self.timer.start(500)  # Update every 500ms
    
    def on_page_selected(self, page_id: int):
        """Handle page selection"""
        self.pages.setCurrentIndex(page_id)
        self.sidebar.highlight_button(page_id)
    
    def update_status(self):
        """Update status bar information"""
        self.status_bar.update_status(
            self.telemetry_interface.rocket.battery,
            self.telemetry_interface.rocket.signal,
            self.telemetry_interface.cansat.battery,
            self.telemetry_interface.cansat.signal,
            self.telemetry_interface.elapsed_time
        )
    
    def receive_rocket_telemetry(self, telemetry: RocketTelemetry):
        """Receive rocket telemetry from backend"""
        self.telemetry_interface.update_rocket_telemetry(telemetry)
    
    def receive_cansat_telemetry(self, telemetry: CanSatTelemetry):
        """Receive CanSat telemetry from backend"""
        self.telemetry_interface.update_cansat_telemetry(telemetry)
    
    def receive_elapsed_time(self, elapsed_seconds: float):
        """Receive mission elapsed time from backend"""
        self.telemetry_interface.update_elapsed_time(elapsed_seconds)


def main():
    """Main entry point"""
    import os
    import traceback
    
    try:
        # Set Qt plugin path for macOS
        if sys.platform == "darwin":
            os.environ["QT_QPA_PLATFORM_PLUGIN_PATH"] = "/Library/Frameworks/Python.framework/Versions/3.13/lib/python3.13/site-packages/PyQt6/Qt6/plugins"
        
        app = QApplication(sys.argv)
        app.setApplicationName("Ground Station")
        
        # Create and show main window
        window = GroundStationApp()
        window.activateWindow()
        window.raise_()
        window.show()
        
        # Start application
        sys.exit(app.exec())
        
    except Exception as e:
        print(f"[ERROR] Failed to start application: {e}")
        traceback.print_exc()
        sys.exit(1)


if __name__ == "__main__":
    main()
