class TelemetryGaugeWidget(QWidget):
    """Semi-circular analog telemetry gauge with enhanced styling"""
    
    def __init__(self, label: str, unit: str, color: str, min_val: float = 0, max_val: float = 100):
        super().__init__()
        self.label = label
        self.unit = unit
        self.color = color
        self.min_val = min_val
        self.max_val = max_val
        self.value = 0
        
        self.setMinimumSize(180, 150)
        self.setStyleSheet(f"""
            QWidget {{
                background-color: {Color.DARK_PANEL};
                border: 2px solid {Color.BORDER};
                border-radius: 8px;
            }}
        """)
        self.setAttribute(Qt.WidgetAttribute.WA_StyledBackground, True)
    
    def set_value(self, value: float):
        """Update gauge value"""
        self.value = max(self.min_val, min(self.max_val, value))
        self.update()
    
    def paintEvent(self, event):
        """Draw semi-circular gauge with enhanced styling"""
        try:
            painter = QPainter(self)
            painter.setRenderHint(QPainter.RenderHint.Antialiasing, True)
            painter.setRenderHint(QPainter.RenderHint.SmoothPixmapTransform, True)
            
            w, h = self.width(), self.height()
            center_x, center_y = w // 2, int(h * 0.65)
            radius = 50
            
            # Draw glow effect for background arc
            glow_color = QColor(self.color)
            glow_color.setAlpha(20)
            pen = QPen(glow_color, 8)
            painter.setPen(pen)
            painter.drawArc(center_x - radius - 4, center_y - radius - 4,
                           (radius + 4) * 2, (radius + 4) * 2, 0, 180 * 16)
            
            # Draw background arc
            pen = QPen(QColor(Color.BORDER), 2.5)
            painter.setPen(pen)
            painter.drawArc(center_x - radius, center_y - radius,
                           radius * 2, radius * 2, 0, 180 * 16)
            
            # Draw value arc with gradient-like appearance
            pen = QPen(QColor(self.color), 4)
            pen.setCapStyle(Qt.PenCapStyle.RoundCap)
            painter.setPen(pen)
            
            # Calculate angle based on value
            progress = (self.value - self.min_val) / (self.max_val - self.min_val) if (self.max_val - self.min_val) > 0 else 0
            progress = max(0, min(1, progress))
            angle = int(progress * 180 * 16)
            painter.drawArc(center_x - radius, center_y - radius,
                           radius * 2, radius * 2, 0, angle)
            
            # Draw needle with glow
            needle_angle = progress * 180 - 90
            needle_rad = math.radians(needle_angle)
            needle_x = center_x + radius * math.cos(needle_rad)
            needle_y = center_y + radius * math.sin(needle_rad)
            
            # Needle glow
            glow_pen = QPen(QColor(self.color), 5)
            glow_pen.setCapStyle(Qt.PenCapStyle.RoundCap)
            glow_color = QColor(self.color)
            glow_color.setAlpha(40)
            glow_pen.setColor(glow_color)
            painter.setPen(glow_pen)
            painter.drawLine(center_x, center_y, int(needle_x), int(needle_y))
            
            # Needle main line
            pen = QPen(QColor(self.color), 2.5)
            pen.setCapStyle(Qt.PenCapStyle.RoundCap)
            painter.setPen(pen)
            painter.drawLine(center_x, center_y, int(needle_x), int(needle_y))
            
            # Draw center circle with gradient effect
            painter.setBrush(QBrush(QColor(self.color)))
            painter.setPen(QPen(QColor(Color.ACCENT_CYAN), 1))
            painter.drawEllipse(center_x - 6, center_y - 6, 12, 12)
            
            # Draw inner circle for depth
            painter.setBrush(QBrush(QColor(Color.DARK_PANEL)))
            painter.drawEllipse(center_x - 3, center_y - 3, 6, 6)
            
            # Draw text with better styling
            font = QFont("Monaco", 9)
            font.setWeight(QFont.Weight.Bold)
            painter.setFont(font)
            painter.setPen(QPen(QColor(Color.TEXT_SECONDARY)))
            
            # Label
            painter.drawText(QRect(0, 8, w, 18), Qt.AlignmentFlag.AlignCenter, self.label)
            
            # Value
            font_size = QFont("Monaco", 10)
            font_size.setWeight(QFont.Weight.Bold)
            painter.setFont(font_size)
            painter.setPen(QPen(QColor(self.color)))
            value_text = f"{self.value:.1f}"
            painter.drawText(QRect(0, center_y + 10, w, 24), 
                            Qt.AlignmentFlag.AlignCenter, value_text)
            
            # Unit
            font_unit = QFont("Monaco", 8)
            painter.setFont(font_unit)
            painter.setPen(QPen(QColor(Color.TEXT_SECONDARY)))
            painter.drawText(QRect(0, center_y + 32, w, 16), 
                            Qt.AlignmentFlag.AlignCenter, self.unit)
            
            painter.end()
        except Exception as e:
            value_text = f"{self.value:.1f} {self.unit}"
            painter.drawText(QRect(0, center_y + 15, w, 30), 
                            Qt.AlignmentFlag.AlignCenter, value_text)
            
            painter.end()
        except Exception as e:
            print(f"[ERROR] in TelemetryGaugeWidget.paintEvent: {e}")


class StateBarWidget(QWidget):
    """Mission state bar showing current phase with enhanced styling"""
    
    def __init__(self, states: List[str], current_state_color: str):
        super().__init__()
        self.states = states
        self.current_idx = 0
        self.current_state_color = current_state_color
        
        self.setMinimumHeight(45)
        self.setStyleSheet(f"""
            QWidget {{
                background-color: {Color.DARK_PANEL};
                border: 1px solid {Color.BORDER};
                border-radius: 6px;
            }}
        """)
    
    def set_state(self, state_name: str):
        """Set current state by name"""
        if state_name in self.states:
            self.current_idx = self.states.index(state_name)
            self.update()
    
    def paintEvent(self, event):
        """Draw state bar with enhanced styling"""
        try:
            painter = QPainter(self)
            painter.setRenderHint(QPainter.RenderHint.Antialiasing, True)
            
            w, h = self.width(), self.height()
            state_width = w // len(self.states)
            
            for i, state in enumerate(self.states):
                x = i * state_width
                
                # Draw background
                if i == self.current_idx:
                    # Active state with glow
                    glow_color = QColor(self.current_state_color)
                    glow_color.setAlpha(40)
                    painter.fillRect(x + 2, 2, state_width - 4, h - 4, QBrush(glow_color))
                    
                    # Active background
                    painter.fillRect(x + 2, 2, state_width - 4, h - 4, 
                                   QBrush(QColor(self.current_state_color)))
                else:
                    # Inactive state
                    painter.fillRect(x + 2, 2, state_width - 4, h - 4, 
                                   QBrush(QColor(Color.BORDER)))
                
                # Draw border
                pen = QPen(QColor(Color.BORDER), 1)
                painter.setPen(pen)
                painter.drawRect(x, 0, state_width, h)
                
                # Draw text
                font = QFont("Monaco", 9, QFont.Weight.Bold)
                painter.setFont(font)
                text_color = QColor(Color.TEXT_PRIMARY) if i == self.current_idx else QColor(Color.TEXT_SECONDARY)
                painter.setPen(QPen(text_color))
                painter.drawText(QRect(x, 0, state_width, h),
                               Qt.AlignmentFlag.AlignCenter, state)
            
            painter.end()
        except Exception as e:
            pass
    
    def set_current_state_color(self, color: str):
        """Update the highlight color"""
        self.current_state_color = color
        self.update()


