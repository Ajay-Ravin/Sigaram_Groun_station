@dataclass
class RocketTelemetry:
    """Rocket telemetry data"""
    altitude: float = 0.0  # meters
    velocity: float = 0.0  # m/s
    acceleration: float = 0.0  # m/s²
    temperature: float = 25.0  # °C
    pressure: float = 1013.0  # hPa
    latitude: float = 0.0
    longitude: float = 0.0
